# ================================================
# IMAGES DIRECTORY — Security Configuration
# ================================================

# Disable directory listing
Options -Indexes

# CRITICAL: Prevent PHP execution inside the images folder.
# Even if someone somehow uploaded a .php file, it won't execute.
<IfModule mod_php.c>
    php_flag engine off
</IfModule>
<IfModule mod_php8.c>
    php_flag engine off
</IfModule>

# Block direct access to any PHP files (belt + suspenders)
<FilesMatch "\.(php|php5|phtml|phar)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Only allow image file types to be served
<FilesMatch "\.(jpg|jpeg|png|gif|webp|svg|ico)$">
    Order Allow,Deny
    Allow from all
</FilesMatch>
